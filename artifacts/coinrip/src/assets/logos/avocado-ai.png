,\"s\":\"$undefined\",\"l\":\"$undefined\",\"p\":\"$undefined\",\"d\":\"$undefined\",\"b\":\"mAt4xsPRTmwafF9IrJx7l\"}\n"])</script><script>self.__next_f.push([1,"f:[]\n9:\"$Wf\"\n10:Tcac,"])</script><script>self.__next_f.push([1,"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is Avocado AI?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Avocado AI is an all-in-one creative platform that replaces 5+ separate tools. Generate professional-quality videos (22+ models including Sora 2 Pro \u0026 Veo 3), images (19+ models), music, voiceovers, and AI UGC — all in one workspace. It includes Storyboards with an infinite canvas for planning campaigns, real-time team collaboration, and Lini, your AI creative director.\"}},{\"@type\":\"Question\",\"name\":\"How do the plans and pricing work?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Avocado AI uses a credit-based system. Plans start at €19.99/month (Intro, 75 credits) and go up to €249/month (Pro, 2,000 credits). Different AI models consume different amounts of credits based on their complexity, and you always see the exact cost before generating. Credits reset each month, and you can upgrade, downgrade, or cancel anytime. All plans include commercial rights and no watermarks.\"}},{\"@type\":\"Question\",\"name\":\"What are the commercial usage rights?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"All content generated with Avocado AI comes with full commercial usage rights. Use your generated images, videos, music, and voiceovers in ads, social media, client work, websites, and any commercial project — without watermarks. Your content is yours to use commercially, even after your subscription ends.\"}},{\"@type\":\"Question\",\"name\":\"What is Lini AI?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Lini is your AI creative director inside Avocado. Tell Lini what you need — describe your campaign, product, or idea in plain language — and Lini orchestrates the right AI models to generate images, videos, music, and more. It's like having a creative assistant that understands your brand and handles the technical work. Lini is available on Starter plans and above.\"}},{\"@type\":\"Question\",\"name\":\"What are Storyboards and the Infinite Canvas?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Storyboards are Avocado's unique visual planning tool: an infinite canvas where you can arrange, compare, and iterate on all your creative assets side by side. Plan ad sequences, map out social campaigns, and manage video series with drag-and-drop scenes. Invite your team to collaborate in real-time.\"}},{\"@type\":\"Question\",\"name\":\"What can I create with Avocado AI?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"AI videos for TikTok, YouTube, and ads. Product photography and marketing images. AI UGC with realistic avatars. Background music and sound effects. Voiceovers in 29+ languages. Visual storyboards for campaign planning. Everything you need for social media, e-commerce, and client work — created in minutes, not days.\"}},{\"@type\":\"Question\",\"name\":\"Why pay for 5 subscriptions when Avocado replaces them all?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Avocado AI replaces Midjourney ($30/mo), ElevenLabs ($22/mo), Suno ($10/mo), Runway ($28/mo), and Canva ($15/mo) — that's $105+/month with 5 separate logins, 5 learning curves, and no unified workflow. Avocado starts at €19.99/month with all tools in one workspace, one credit system, and full commercial rights.\"}}]}"])</script><script>self.__next_f.push([1,"2:[\"$\",\"html\",null,{\"lang\":\"en\",\"suppressHydrationWarning\":true,\"children\":[[\"$\",\"head\",null,{\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"Avocado AI\\\",\\\"url\\\":\\\"https://w